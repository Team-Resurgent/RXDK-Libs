# clangd configuration for RXDK-Libs.
#
# Everything here compiles for the Xbox: 32-bit x86, MS-extensions, freestanding.
# clangd otherwise analyzes opened files with host (x86_64) defaults, which trips
# target guards in the headers — e.g. picolibc machine/x86 _tls.h does
# `#if !defined(__i386__) && !defined(__x86_64__) #error`. Targeting i386 (and
# defining __i386__ directly, in case clangd's driver ignores the triple) plus
# the shared header roots makes standalone header analysis match the real build.
CompileFlags:
  Add:
    - --target=i686-pc-windows-gnu
    - -D__i386__
    - -fms-extensions
    - -fms-compatibility
    - -D_X86_
    - -Di386
    - -D_M_IX86=600
    - -D_XBOX
    - -Ishared/include
    - -Ishared/picolibc/include
    - -Ishared/picolibc/machine/x86
    - -Iinclude
    - -Ibuild/generated

---
# C++ translation units additionally get the libcxx header root (kept off the C
# path so C files don't pull libcxx's __config_site).
If:
  PathMatch: [.*\.(cpp|cxx|cc|hpp|hh)]
CompileFlags:
  Add:
    - -Ishared/libcxx/include
    - -Ibuild/generated/libcxx

---
# libxapi internal sources (libs/libxapi/**) pull their type environment
# from a bridge header (e.g. #include "bridge_k32.h") that lives in the slice's
# internal include dirs, plus the build's force-included picolibc.h/profile.h.
# Give clangd those dirs + force-includes so internal types (POBJECT_STRING,
# OBJECT_STRING, etc.) resolve when one of these files is opened standalone.
If:
  PathMatch: [libs/libxapi/.*]
CompileFlags:
  Add:
    - -include
    - picolibc.h
    - -include
    - libs/libxapi/site/profile.h
    - -Ilibs/libxapi/internal
    - -Ilibs/libxapi/internal/shims
    - -Ilibs/libxapi/site
    - -Ilibs/libxapi/nt
    - -Ilibs/libxapi/k32
    - -Ilibs/libxapi/k32/inc
    - -Ilibs/libxapi/dll
    - -Ilibs/libxapi/rtl
    - -Ilibs/libxapi/rtl/inc
    - -Ilibs/libxapi/uuid
    - -Ilibs/libxapi/usb/inc
    - -Ilibs/libxapi/usb/ohcd
    - -Ilibs/libxapi/usb/usbd
    - -Ilibs/libxapi/usb/hub
    - -Ilibs/libxapi/usb/mu
    - -Ilibs/libxapi/usb/xid
    - -Ilibs/libxapi/support/inc
    - -Ilibs/libxapi/support/inc/ntos
    - -Ilibs/libxapi/support/fatx
    - -Ilibs/libxapi/support/idex
    - -Ilibs/libxapi/support/crypto
    - -Ilibs/libxapi/port
